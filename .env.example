# ── Next.js app (Vercel) ──────────────────────────────────────────────────────
# Postgres (Vercel Postgres / Neon). Use the pooled connection string.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Better Auth — generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Magic-link / verification email (optional in dev — without it, links are
# printed to the server console instead of sent).
RESEND_API_KEY=
EMAIL_FROM=Transit DAW <onboarding@resend.dev>

# AI Composer — proxied same-origin via /api/compose (key stays server-side)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Server-side: /api/snapshot proxies to the feed service at this URL
FEED_HTTP_URL=http://localhost:3005

# ── Feed service (separate always-on process) ─────────────────────────────────
BKK_API_KEY=
PORT=3005

# Client connects directly to the feed's WebSocket (can't proxy WS via serverless)
NEXT_PUBLIC_FEED_WS_URL=ws://localhost:3005
