# Which city to serve. Must match a descriptor in feed/cities/ (default: budapest).
CITY=budapest

# BKK GTFS-RT API key — required when CITY=budapest (free: https://opendata.bkk.hu/data-sources)
BKK_API_KEY=

# Helsinki (HSL) — the realtime.hsl.fi GTFS-RT feeds are currently public, so no
# key is needed for CITY=helsinki. If HSL later gates them, set this and switch
# the descriptor's auth to a digitransit-subscription-key header.
# HSL_API_KEY=

# Port the HTTP + WebSocket server listens on.
PORT=3005

# CORS allowlist for the HTTP endpoints. '*' allows any origin (default).
# In production set to your Next app origin, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=*
